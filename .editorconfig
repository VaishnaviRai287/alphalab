root = true

# ---------------------------------------------------------------------------
# Global defaults — apply to all files unless overridden below
# ---------------------------------------------------------------------------
[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# ---------------------------------------------------------------------------
# Markdown — preserve trailing spaces (they create line breaks in some renderers)
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# ---------------------------------------------------------------------------
# YAML — 2-space indentation is the universal convention
# ---------------------------------------------------------------------------
[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

# ---------------------------------------------------------------------------
# JSON — 2-space indentation
# ---------------------------------------------------------------------------
[*.json]
indent_size = 2

# ---------------------------------------------------------------------------
# TOML — 4-space indentation
# ---------------------------------------------------------------------------
[*.toml]
indent_size = 4

# ---------------------------------------------------------------------------
# JavaScript / TypeScript (web/)
# ---------------------------------------------------------------------------
[*.{js,jsx,ts,tsx}]
indent_size = 2

# ---------------------------------------------------------------------------
# CSS / SCSS (web/)
# ---------------------------------------------------------------------------
[*.{css,scss}]
indent_size = 2

# ---------------------------------------------------------------------------
# Makefile — tabs are syntactically required
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.sh]
indent_size = 2
