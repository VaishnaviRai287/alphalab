# =============================================================================
# AlphaLab — Environment Variables Template
# =============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file to .env in the project root:
#        cp infra/.env.example .env
#   2. Fill in every value marked <required>
#   3. Never commit the .env file — it is gitignored
#   4. Never commit real credentials anywhere in this repository
#
# This file is committed to git as the single source of truth for which
# environment variables the application requires. The .env file with real
# values is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=alphalab
POSTGRES_PASSWORD=<required: choose a strong password>
POSTGRES_DB=alphalab
POSTGRES_PORT=5432

# Full connection URL (used by the application and SQLAlchemy)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://alphalab:<your-password>@localhost:5432/alphalab

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=<required: choose a strong password>
REDIS_PORT=6379

# Full connection URL (used by Celery as broker and result backend)
REDIS_URL=redis://:your-password@localhost:6379/0

# Celery-specific URLs (broker and result backend may differ in production)
CELERY_BROKER_URL=redis://:your-password@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:your-password@localhost:6379/1

# -----------------------------------------------------------------------------
# pgAdmin (optional — only needed when running with --profile tools)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@alphalab.local
PGADMIN_PASSWORD=<required: choose a strong password>
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# Path to the DuckDB database file (relative to project root or absolute)
DUCKDB_PATH=./data/alphalab.duckdb

# JWT secret for authentication (Phase 6)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<required: generate a random 32-byte hex string>
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
